      "name": "ui-ux-pro-max",
      "role": [
        "data",
        "checklist",
        "audit"
      ],
      "repo": "https://github.com/nextlevelbuilder/ui-ux-pro-max-skill",
      "ref": "v2.9.0",
      "update": {
        "track": "tag",
        "pattern": "v*"
      },
      "sourceSubpath": ".claude/skills/ui-ux-pro-max",
      "target": "website-ux",
      "license": "MIT",
      "licenseFile": "LICENSE",
      "frontmatterSet": {
        "disable-model-invocation": true,
        "name": "website-ux"
      },
      "pathRewrites": [
        {
          "from": "skills/ui-ux-pro-max",
          "to": "${CLAUDE_PLUGIN_ROOT}/skills/website-ux"
        }
      ]
    },
